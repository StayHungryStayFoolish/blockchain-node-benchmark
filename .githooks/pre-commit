#!/usr/bin/env bash
# .githooks/pre-commit
# Monitoring entry guard runs before relevant commits.
#
# Install:  git config core.hooksPath .githooks
# Bypass:   git commit --no-verify  (use only when fixing the hook itself)

set -u
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Only run if the relevant files are touched — fast path for unrelated commits.
touched_relevant=$(git diff --cached --name-only \
    | grep -E '^(monitoring/|tools/|ci/check_parallel_entry\.sh$|deploy/k8s/|config/)' \
    || true)

if [[ -z "$touched_relevant" ]]; then
    exit 0
fi

if [[ ! -x ci/check_parallel_entry.sh ]]; then
    echo "pre-commit: ci/check_parallel_entry.sh missing or not executable — skipping" >&2
    exit 0
fi

echo "[pre-commit] running ci/check_parallel_entry.sh..."
if ! bash ci/check_parallel_entry.sh; then
    echo "" >&2
    echo "═══════════════════════════════════════════════════════════════════════" >&2
    echo "  pre-commit BLOCKED: monitoring entry guard failed" >&2
    echo "═══════════════════════════════════════════════════════════════════════" >&2
    echo "  Fix the violations above, OR update PARALLEL_ENTRY_RULES if the" >&2
    echo "  dependency genuinely changed. Bypass with --no-verify only when" >&2
    echo "  fixing the hook itself." >&2
    exit 1
fi
exit 0
